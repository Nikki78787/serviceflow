generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  USER
  PLATFORM_ADMIN
}

enum MembershipRole {
  OWNER
  STAFF
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  BUSINESS_DASHBOARD
  CUSTOMER_PORTAL
  PHONE
  WALK_IN
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING
  PAID
  OVERDUE
  VOID
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  MANUAL
}

enum PaymentMethod {
  CARD
  FPX
  CASH
  BANK_TRANSFER
  E_WALLET
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_UPDATED
  BOOKING_CANCELLED
  INVOICE_CREATED
  PAYMENT_RECEIVED
  SYSTEM
}

enum FileCategory {
  BUSINESS_LOGO
  CUSTOMER_DOCUMENT
  RECEIPT
  INVOICE_ATTACHMENT
  OTHER
}

model User {
  id              String       @id @default(cuid())
  name            String?
  email           String       @unique
  passwordHash    String
  imageUrl        String?
  phone           String?
  platformRole    PlatformRole @default(USER)
  emailVerifiedAt DateTime?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  memberships       BusinessMember[]
  customerProfiles  Customer[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  uploadedFiles     FileUpload[]
  passwordReset     PasswordResetToken?
  emailVerification EmailVerificationToken?
}

model Business {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  email          String?
  phone          String?
  address        String?
  description    String?
  logoUrl        String?
  timezone       String   @default("Asia/Kuala_Lumpur")
  currency       String   @default("MYR")
  bookingEnabled Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members       BusinessMember[]
  staff         Staff[]
  services      Service[]
  customers     Customer[]
  appointments  Appointment[]
  invoices      Invoice[]
  notifications Notification[]
  auditLogs     AuditLog[]
  files         FileUpload[]

  @@index([slug])
}

model BusinessMember {
  id         String           @id @default(cuid())
  businessId String
  userId     String
  role       MembershipRole   @default(STAFF)
  status     MembershipStatus @default(ACTIVE)
  jobTitle   String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability StaffAvailability[]
  appointments Appointment[]

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
}

model Staff {
  id         String   @id @default(cuid())
  businessId String
  fullName   String
  email      String?
  phone      String?
  position   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  availability StaffAvailability[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([businessId, isActive])
}

model Service {
  id              String   @id @default(cuid())
  businessId      String
  name            String
  description     String?
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  invoiceItems InvoiceItem[]

  @@unique([businessId, name])
  @@index([businessId])
}

model StaffAvailability {
  id               String   @id @default(cuid())
  businessMemberId String?
  staffId          String?
  dayOfWeek        Int
  startTime        String
  endTime          String
  isAvailable      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  businessMember BusinessMember? @relation(fields: [businessMemberId], references: [id], onDelete: Cascade)
  staff          Staff?          @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([businessMemberId, dayOfWeek, startTime, endTime])
  @@unique([staffId, dayOfWeek, startTime, endTime])
  @@index([businessMemberId, dayOfWeek])
  @@index([staffId, dayOfWeek])
}

model Customer {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  fullName   String
  email      String?
  phone      String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  invoices     Invoice[]
  files        FileUpload[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([userId])
}

model Appointment {
  id                 String            @id @default(cuid())
  businessId         String
  serviceId          String
  customerId         String
  staffMemberId      String?
  staffProfileId     String?
  startTime          DateTime
  endTime            DateTime
  status             AppointmentStatus @default(PENDING)
  bookingSource      BookingSource     @default(BUSINESS_DASHBOARD)
  customerNotes      String?
  internalNotes      String?
  cancellationReason String?
  finalPrice         Decimal           @db.Decimal(10, 2)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  business     Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service      Service         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  staffMember  BusinessMember? @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  staffProfile Staff?          @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)
  invoice      Invoice?
  files        FileUpload[]

  @@index([businessId, startTime])
  @@index([customerId, startTime])
  @@index([staffMemberId, startTime])
  @@index([staffProfileId, startTime])
  @@index([status])
}

model Invoice {
  id            String        @id @default(cuid())
  businessId    String
  customerId    String
  appointmentId String?       @unique
  invoiceNumber String
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  subtotal      Decimal       @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        InvoiceStatus @default(DRAFT)
  notes         String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  appointment Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  items       InvoiceItem[]
  payments    Payment[]
  files       FileUpload[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId, status])
  @@index([customerId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  serviceId   String?
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

model Payment {
  id                String          @id @default(cuid())
  invoiceId         String
  provider          PaymentProvider @default(MANUAL)
  method            PaymentMethod?
  status            PaymentStatus   @default(PENDING)
  amount            Decimal         @db.Decimal(10, 2)
  providerReference String?         @unique
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  businessId String?
  type       NotificationType @default(SYSTEM)
  title      String
  message    String
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([businessId])
}

model AuditLog {
  id          String   @id @default(cuid())
  businessId  String
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  beforeData  Json?
  afterData   Json?
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([businessId, entityType, entityId])
  @@index([actorUserId])
}

model FileUpload {
  id               String       @id @default(cuid())
  businessId       String
  uploadedByUserId String?
  customerId       String?
  appointmentId    String?
  invoiceId        String?
  fileName         String
  fileUrl          String
  publicId         String?
  mimeType         String
  sizeBytes        Int
  category         FileCategory @default(OTHER)
  createdAt        DateTime     @default(now())

  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  uploadedBy  User?        @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([customerId])
  @@index([appointmentId])
  @@index([invoiceId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}
